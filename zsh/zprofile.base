# zsh login profile
#
# Sourced by ~/.zprofile when a login zsh starts. It loads shared login
# environment, then zsh-specific login overlay if present.

# helper (needed here; zshrc.base is not sourced in all login contexts)
source_if_exists() { [ -f "$1" ] && . "$1"; }

# load shared login environment
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# private overlay (host‑specific or sensitive additions)
source_if_exists "$HOME/.config/dotfiles-private/zsh/zprofile.private"
